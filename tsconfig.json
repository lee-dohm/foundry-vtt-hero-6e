{
	"compilerOptions": {
    "moduleResolution": "node",
		"target": "ES2018",
		"lib": [
      "ES2018",
      "DOM"
		],
		"outDir": "modules",
		"sourceMap": true,
		"rootDir": "src",
		"experimentalDecorators": true,
		"strict": true,
		"esModuleInterop": true,
    "types": ["@league-of-foundry-developers/foundry-vtt-types", "node"]
	},
	"include": ["src/**/*"]
}
